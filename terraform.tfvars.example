prefix              = "database-demo"
region              = "ng-abuja-1"

# network_name = "default"

# Managed Databases — turn on what you need
pg_enabled          = true
pg_version          = "16"
mysql_enabled       = false
mysql_version       = "8.4"
db_flavor           = "r1.medium"    # r1.* = RAM-optimised
db_size_gb          = 20

# Cache (Redis / memcached)
cache_enabled       = true
cache_engine        = "redis"
cache_version       = "7.2"
cache_flavor        = "m1.small"


# Optional — only set if you have a custom Trove datastore template that
# binds Postgres / MySQL on a non-standard port.
# postgres_port = 5432
# mysql_port    = 3306
# enable_root = false   # set true only if you need a privileged user
